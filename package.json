{
	"name": "obsidian-plugin-journal-review",
	"version": "3.1.2",
	"description": "Review your daily notes on their anniversaries, like \"what happened today last year\"\n\n",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --test --require ts-node/register/transpile-only tests/*.test.ts",
		"version": "node version-bump.mjs && npm run format && git add manifest.json versions.json",
		"lint": "eslint . && knip && prettier --check .",
		"format": "prettier --write .",
		"generateNotes": "ts-node ./scripts/generateNotes.ts vault 5",
		"knip": "knip"
	},
	"keywords": [],
	"author": "Kageetai",
	"license": "MIT",
	"engines": {
		"node": ">=20.11.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"@typescript-eslint/parser": "^8.63.0",
		"esbuild": "^0.28.1",
		"esbuild-plugin-copy": "^2.1.1",
		"eslint": "^10.6.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"globals": "^17.7.0",
		"knip": "^6.25.0",
		"moment": "^2.30.1",
		"obsidian": "latest",
		"prettier": "^3.9.4",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"obsidian-daily-notes-interface": "^0.9.5",
		"preact": "^10.29.5"
	},
	"overrides": {
		"obsidian-daily-notes-interface": {
			"obsidian": "$obsidian"
		}
	}
}
